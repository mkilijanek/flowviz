{
  "name": "flowviz",
  "version": "1.0.0",
  "description": "AI-powered cybersecurity attack flow visualization tool using MITRE ATT&CK",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server.js",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "tsc && vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "start": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:prod": "npm audit --omit=dev",
    "smoke:release": "node scripts/release-smoke.mjs",
    "verify:release": "npm run lint && npm test && npm run build && npm run smoke:release && npm run audit:prod && docker compose config && docker compose build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@mozilla/readability": "^0.6.0",
    "@mui/icons-material": "^5.15.10",
    "@mui/material": "^5.15.10",
    "@tanstack/react-query": "^5.90.21",
    "@types/dagre": "^0.7.53",
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "dagre": "^0.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "file-type": "^21.0.0",
    "helmet": "^8.1.0",
    "html-to-image": "^1.11.13",
    "http-proxy-middleware": "^2.0.6",
    "ip-address": "^10.0.1",
    "jsdom": "^26.1.0",
    "node-fetch": "^3.3.2",
    "openai": "^6.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.10.3",
    "uuid": "^9.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "supertest": "^7.2.2",
    "terser": "^5.43.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "lodash": "4.17.23",
    "qs": "6.15.0"
  },
  "main": "eslint.config.js"
}
