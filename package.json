{
  "name": "flowviz",
  "version": "1.0.2",
  "description": "AI-powered cybersecurity attack flow visualization tool using MITRE ATT&CK",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.19 <25",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "server": "node server.js",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "tsc && vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "start": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:prod": "npm audit --omit=dev",
    "smoke:release": "node scripts/release-smoke.mjs",
    "verify:release": "npm run lint && npm test && npm run build && npm run smoke:release && npm run audit:prod && docker compose config && docker compose build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.14.1",
    "@mozilla/readability": "^0.6.0",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.18.0",
    "@tanstack/react-query": "^5.100.9",
    "@types/dagre": "^0.7.54",
    "axios": "^1.16.0",
    "cors": "^2.8.6",
    "dagre": "^0.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "express-rate-limit": "^8.4.1",
    "file-type": "^21.3.4",
    "helmet": "^8.1.0",
    "html-to-image": "^1.11.13",
    "http-proxy-middleware": "^2.0.6",
    "ip-address": "^10.2.0",
    "jsdom": "^26.1.0",
    "node-fetch": "^3.3.2",
    "openai": "^6.35.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "reactflow": "^11.10.3",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "supertest": "^7.2.2",
    "terser": "^5.46.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "lodash": "4.17.23",
    "qs": "6.15.0",
    "js-yaml": "4.1.1",
    "eslint": {
      "minimatch": "3.1.5"
    },
    "@eslint/eslintrc": {
      "minimatch": "3.1.5"
    },
    "@humanwhocodes/config-array": {
      "minimatch": "3.1.5"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": "9.0.7"
    }
  },
  "main": "eslint.config.js"
}
